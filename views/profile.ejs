<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<div class="main-content flex-grow-1 p-4">
    <div class="text-center mb-5">
        <img src="<%= user.anhDaiDien %>" class="rounded-circle shadow"
            style="width: 120px; height: 120px; border: 4px solid white; object-fit: cover;">
        <h2 class="fw-bold mt-3">
            <%= user.hoTen %>
        </h2>
    </div>

    <ul class="nav nav-pills justify-content-center mb-4 gap-3" id="pills-tab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-bold px-4 rounded-pill" data-bs-toggle="pill" data-bs-target="#tab-dadang"
                type="button" role="tab" style="background-color: #0d6efd; color: white;">
                Ảnh đã đăng
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold px-4 rounded-pill" data-bs-toggle="pill" data-bs-target="#tab-daluu"
                type="button" role="tab" style="background-color: #ffc107; color: black;">
                Đã lưu
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold px-4 rounded-pill" data-bs-toggle="pill" data-bs-target="#tab-yeuthich"
                type="button" role="tab" style="background-color: #dc3545; color: white;">
                Đã thích
            </button>
        </li>
    </ul>

    <div class="tab-content" id="pills-tabContent">

        <div class="tab-pane fade show active" id="tab-dadang" role="tabpanel">
            <div class="luoi-anh-cxe">
                <% myPosts.forEach(function(item) { %>
                    <div class="item-anh position-relative">
                        <a href="/chi_tiet/<%= item._id %>"><img src="<%= item.urlanh %>" class="w-100 rounded-4"></a>
                        <div class="overlay-anh d-flex flex-column justify-content-center gap-2">
                            <button class="btn btn-light btn-sm rounded-pill px-3 fw-bold"
                                onclick="moModalSua('<%= item._id %>', '<%= item.tieude %>', '<%= item.mota %>')">
                                <i class="fa-solid fa-pen"></i> Sửa
                            </button>
                            <form action="/profile/xoa/<%= item._id %>" method="POST"
                                onsubmit="return confirm('Xóa thiệt hả bác?')">
                                <button type="submit" class="btn btn-danger btn-sm rounded-pill px-3 w-100 fw-bold"><i
                                        class="fa-solid fa-trash"></i> Xóa</button>
                            </form>
                        </div>
                    </div>
                    <% }) %>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-daluu" role="tabpanel">
            <div class="luoi-anh-cxe">
                <% savedPosts.forEach(function(item) { %>
                    <div class="item-anh position-relative">
                        <a href="/chi_tiet/<%= item._id %>"><img src="<%= item.urlanh %>" class="w-100 rounded-4"></a>
                        <div class="overlay-anh d-flex flex-column justify-content-center gap-2">
                            <form action="/save/<%= item._id %>" method="POST">
                                <input type="hidden" name="returnUrl" value="/profile">
                                <button type="submit" class="btn btn-dark btn-sm rounded-pill px-3 w-100 fw-bold"><i
                                        class="fa-solid fa-bookmark-slash"></i> Bỏ lưu</button>
                            </form>
                        </div>
                    </div>
                    <% }) %>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-yeuthich" role="tabpanel">
            <div class="luoi-anh-cxe">
                <% likedPosts.forEach(function(item) { %>
                    <div class="item-anh position-relative">
                        <a href="/chi_tiet/<%= item._id %>"><img src="<%= item.urlanh %>" class="w-100 rounded-4"></a>
                        <div class="overlay-anh d-flex flex-column justify-content-center gap-2">
                            <form action="/like/<%= item._id %>" method="POST">
                                <input type="hidden" name="returnUrl" value="/profile">
                                <button type="submit"
                                    class="btn btn-outline-danger btn-sm rounded-pill px-3 w-100 fw-bold bg-white"><i
                                        class="fa-solid fa-heart-crack"></i> Bỏ thích</button>
                            </form>
                        </div>
                    </div>
                    <% }) %>
            </div>
        </div>

    </div>

</div>
</div>

<div class="modal fade" id="modalSua" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <form id="formSua" action="" method="POST">
                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold">Chỉnh sửa bài đăng</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tiêu đề mới</label>
                        <input type="text" name="tieude_moi" id="inputTieude" class="form-control rounded-3" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mô tả mới</label>
                        <textarea name="mota_moi" id="inputMota" class="form-control rounded-3" rows="4"
                            placeholder="Viết gì đó về tấm ảnh này..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-warning rounded-pill px-4 fw-bold">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function moModalSua(id, tieude, mota) {

        document.getElementById('formSua').action = '/profile/sua/' + id;

        document.getElementById('inputTieude').value = tieude;

        document.getElementById('inputMota').value = (mota === 'undefined' || !mota) ? '' : mota;

        var myModal = new bootstrap.Modal(document.getElementById('modalSua'));
        myModal.show();
    }
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    // Ban đầu làm mờ 2 tab không được chọn
    document.querySelectorAll('#pills-tab .nav-link').forEach(btn => {
        if (!btn.classList.contains('active')) {
            btn.style.opacity = '0.5';
        }
    });

    // Khi click vào tab nào thì bật sáng tab đó lên, làm mờ bọn còn lại
    document.querySelectorAll('#pills-tab .nav-link').forEach(button => {
        button.addEventListener('click', function() {
            document.querySelectorAll('#pills-tab .nav-link').forEach(btn => btn.style.opacity = '0.5');
            this.style.opacity = '1';
        });
    });
</script>