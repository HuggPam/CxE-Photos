<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CxE Photos - Ảnh đã chọn</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="text-dark fw-medium">

    <div class="d-flex">
        <div class="sidebar d-flex flex-column align-items-center">
            <a href="/" class="sidebar-logo"> <img src="/images/logo.png" alt="Logo" class="img-logo"></a>
            <a href="/" class="sidebar-item">
                <i class="fa-solid fa-house"></i>
            </a>
            <a href="/thu_vien" class="sidebar-item active">
                <i class="fa-solid fa-cloud"></i>
            </a>
            <a href="/upload" class="sidebar-item">
                <i class="fa-solid fa-plus"></i>
            </a>
        </div>

        <div class="main-content flex-grow-1">
            <div class="top-bar">
                <div class="header-container">
                    <div class="search-box">
                        <i class="fa fa-search"></i>
                        <input type="text" class="search-input" placeholder="Tìm kiếm hình ảnh...">
                    </div>

                    <div class="user-profile">
                        <% if (user) { %>
                            <img src="<%= user.anhDaiDien %>" alt="Avatar" class="avatar-circle" title="<%= user.hoTen %>">
                            <a href="/auth/logout" class="btn-logout">Đăng xuất</a>
                        <% } else { %>
                            <a href="/auth/google" class="btn-dang-nhap">Đăng nhập</a>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="container-fluid mt-3">
                <div class="d-flex justify-content-between align-items-center mb-4 ps-2 pe-3">
                    <h4>Ảnh bạn vừa lấy từ Google</h4>
                    <a href="/thu_vien" class="btn btn-outline-primary btn-sm rounded-pill fw-bold">
                        <i class="fa-solid fa-images"></i> Chọn thêm ảnh khác
                    </a>
                </div>

                <div class="luoi-anh-cxe">
                    <% if (images && images.length > 0) { %>
                        <% images.forEach(function(item) { %>
                            <div class="item-anh">
                                <img src="/thu_vien/anh-proxy?url=<%= encodeURIComponent(item.mediaFile.baseUrl + '=w500') %>" alt="Ảnh từ Google Photos" loading="lazy">

                                <div class="overlay-anh">
                                    <form action="/thu_vien/chia-se" method="POST" class="p-2 w-100">
                                        <input type="hidden" name="urlgoc" value="<%= item.mediaFile.baseUrl %>">
                                        <input type="text" name="tieude" class="form-control form-control-sm mb-2"
                                            placeholder="Đặt tiêu đề ảnh..." required>
                                        <button type="submit" class="btn btn-warning btn-sm w-100 fw-bold">
                                            <i class="fa-solid fa-cloud-arrow-up"></i> Chia sẻ
                                        </button>
                                    </form>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="thong-bao-trong text-center mt-5 w-100">
                            <i class="fa-solid fa-cloud-sun fa-3x text-muted mb-3"></i>
                            <p class="fs-5 text-muted">Bạn chưa chọn tấm ảnh nào!</p>
                            <a href="/thu_vien" class="btn btn-primary mt-2">Mở kho ảnh Google ngay</a>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <script>
        const sidebarItems = document.querySelectorAll('.sidebar-item');
        sidebarItems.forEach(item => {
            item.addEventListener('click', function () {
                sidebarItems.forEach(i => i.classList.remove('active'));
                this.classList.add('active');
            });
        });
    </script>
</body>

</html>