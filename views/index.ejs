<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CxE Photos - Lưu trữ đám mây</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="text-dark fw-medium">

    <div class="d-flex">
        <div class="sidebar d-flex flex-column align-items-center"> 
            <a href="/" class="sidebar-logo"> <img src="/images/logo.png" alt="Logo" class="img-logo"></a>

            <a href="/" class="sidebar-item active">
                <i class="fa-solid fa-house"></i>
            </a>
            <div class="sidebar-action-wrapper">
                <a href="#" class="sidebar-item" id="btn-create">
                    <i class="fa-solid fa-plus"></i>
                </a>
                
                <div class="create-menu-popover" id="createMenu">
                    <div class="menu-title">Tạo</div>
                    
                    <a href="/upload" class="menu-item">
                        <div class="menu-icon"><i class="fa-solid fa-thumbtack"></i></div>
                        <div class="menu-text">
                            <strong>Ghim</strong>
                            <span>Đăng ảnh hoặc video và thêm liên kết...</span>
                        </div>
                    </a>

                    <a href="#" class="menu-item">
                        <div class="menu-icon"><i class="fa-solid fa-table-cells-large"></i></div>
                        <div class="menu-text">
                            <strong>Bảng</strong>
                            <span>Sắp xếp một bộ sưu tập Ghim bạn yêu thích...</span>
                        </div>
                    </a>
                </div>
            </div>
            <a href="/profile" class="sidebar-item mt-auto">
                <i class="fa-solid fa-user"></i>
            </a>
        </div>

        <div class="main-content flex-grow-1">
            <div class="top-bar">
                <div class="header-container">
                    <div class="search-box">
                        <i class="fa fa-search"></i>
                        <input type="text" class="search-input" placeholder="Tìm kiếm hình ảnh...">
                    </div>

                    <div class="user-profile">
                        <% if (user) { %>
                            <img src="<%= user.anhDaiDien %>" alt="Avatar" class="avatar-circle"
                                title="<%= user.hoTen %>">
                            <a href="/auth/logout" class="btn-logout">Đăng xuất</a>
                            <% } else { %>
                                <a href="/auth/google" class="btn-dang-nhap">Đăng nhập</a>
                                <% } %>
                    </div>
                </div>
            </div>
        
            <div class="container-fluid mt-3">
               <div class="luoi-anh-cxe">
                    <% if (images && images.length > 0) { %>
                        <% images.forEach(function(post) { %>
                            <div class="item-anh">
                                <a href="/photo/<%= post._id %>">
                                    <img src="<%= post.imageUrl %>" alt="<%= post.title %>" loading="lazy">
                                </a>
                                
                                <div class="overlay-anh">
                                    <button class="btn-luu-anh">Lưu</button>
                                </div>
                                
                                <p class="mt-2 fw-bold" style="font-size: 14px; padding-left: 5px;">
                                    <%= post.title %>
                                </p>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="w-100 text-center mt-5">
                            <p class="text-muted">Chưa có bài đăng nào. Hãy là người đầu tiên đăng ảnh!</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div> 
    </div>
    <script>
        const sidebarItems = document.querySelectorAll('.sidebar-item');
        sidebarItems.forEach(item => {
            item.addEventListener('click', function () {
                sidebarItems.forEach(i => i.classList.remove('active'));
                this.classList.add('active');
            });
        });
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const btnCreate = document.getElementById('btn-create');
            const createMenu = document.getElementById('createMenu');

            // Bật/tắt menu khi nhấn nút +
            btnCreate.addEventListener('click', function(e) {
                e.preventDefault(); // Ngăn trình duyệt nhảy lên đầu trang
                createMenu.classList.toggle('show');
            });

            // Tự động đóng menu nếu click ra ngoài
            document.addEventListener('click', function(e) {
                if (!btnCreate.contains(e.target) && !createMenu.contains(e.target)) {
                    createMenu.classList.remove('show');
                }
            });
        });
    </script>
</body>

</html>