<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CxE Photos - Lưu trữ đám mây</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="text-dark fw-medium">

    <div class="d-flex">
        <div class="sidebar d-flex flex-column align-items-center"> 
            <a href="/" class="sidebar-logo"> <img src="/images/logo.png" alt="Logo" class="img-logo"></a>

            <a href="/" class="sidebar-item active">
                <i class="fa-solid fa-house"></i>
            </a>
            <a href="/upload" class="sidebar-item">
                <i class="fa-solid fa-plus"></i>
            </a>
            <a href="/profile" class="sidebar-item mt-auto">
                <i class="fa-solid fa-user"></i>
            </a>
        </div>

        <div class="main-content flex-grow-1">
            <div class="top-bar">
                <div class="header-container">
                    <div class="search-box">
                        <i class="fa fa-search"></i>
                        <input type="text" class="search-input" placeholder="Tìm kiếm hình ảnh...">
                    </div>

                    <div class="user-profile">
                        <% if (user) { %>
                            <img src="<%= user.anhDaiDien %>" alt="Avatar" class="avatar-circle"
                                title="<%= user.hoTen %>">
                            <a href="/auth/logout" class="btn-logout">Đăng xuất</a>
                            <% } else { %>
                                <a href="/auth/google" class="btn-dang-nhap">Đăng nhập</a>
                                <% } %>
                    </div>
                </div>
            </div>

            <div class="container-fluid mt-3">
                <div class="luoi-anh-cxe">
                    <% 
    // 1. Định nghĩa mảng gốc 10 tấm
    const anhGoc = [
        "https://picsum.photos/300/400", "https://picsum.photos/300/200",
        "https://picsum.photos/300/500", "https://picsum.photos/300/300",
        "https://picsum.photos/300/450", "https://picsum.photos/300/250",
        "https://picsum.photos/300/600", "https://picsum.photos/300/350",
        "https://picsum.photos/300/420", "https://picsum.photos/300/280"
    ]; 
    
    // 2. Nhân bản lên thành 20 tấm bằng cách nối mảng (Dùng concat cho an toàn)
    const anhMau = anhGoc.concat(anhGoc); 
%>

                        <% anhMau.forEach(function(url) { %>
                            <div class="item-anh">
                                <img src="<%= url %>" alt="Ảnh CxE Photos" loading="lazy">
                                <div class="overlay-anh">
                                    <button class="btn-luu-anh">Lưu</button>
                                </div>
                            </div>
                            <% }); %>
                </div>
            </div>
        </div>
    </div>

    <script>
        const sidebarItems = document.querySelectorAll('.sidebar-item');
        sidebarItems.forEach(item => {
            item.addEventListener('click', function () {
                sidebarItems.forEach(i => i.classList.remove('active'));
                this.classList.add('active');
            });
        });
    </script>
</body>

</html>